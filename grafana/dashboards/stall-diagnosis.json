            "fillOpacity": 80,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 30000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\", event_name=\"tool_result\"} | json | unwrap duration_ms [1m]",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "📊 Top 10 Slowest Events (All Types)",
      "description": "The single most useful panel — shows the slowest individual events across all categories.",
      "type": "table",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} | duration_ms != \"0\"",
          "queryType": "range",
          "refId": "A",
          "maxLines": 500
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "format": "auto"
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              { "field": "duration_ms", "desc": true }
            ]
          }
        },
        {
          "id": "limit",
          "options": { "limitField": 10 }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      }
    },
    {
      "title": "⏱️ Session Token Usage Over Time",
      "description": "Tracks input/output/cache tokens. Context bloat = bigger input tokens = slower API responses.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(claude_code_token_usage_tokens_total[5m])",
          "legendFormat": "{{type}} ({{model}})",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "💰 Cost Accumulation",
      "description": "Running cost per session. Spikes correlate with large context windows and retries.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "claude_code_cost_usage_USD_total",
          "legendFormat": "Cost ({{model}})",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "🔄 Permission Decisions (Accept vs Deny latency)",
      "description": "Time spent waiting on permission prompts. 'ask' decisions block until you respond.",
