        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\", event_name=~\"tool_decision.*\"} | json | unwrap duration_ms [1m]",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "{{tool_name}} ({{decision_type}})"
        }
      ]
    },
    {
      "title": "📈 Event Volume by Type",
      "description": "How many events of each type are firing. High tool_result counts = lots of hook activity.",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "targets": [
        {
          "expr": "sum by (event_name) (count_over_time({service_name=\"claude-code\"}[1h]))",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "{{event_name}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut"
      }
