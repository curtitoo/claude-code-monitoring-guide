  "panels": [
    {
      "title": "🔴 API Request Duration (The Main Bottleneck)",
      "description": "How long each API call to Anthropic takes. Spikes = API-side stalls. Your avg is ~21s, max hit 295s.",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 6,
            "showPoints": "always",
            "thresholdsStyle": { "mode": "dashed" }
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 30000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\", event_name=\"api_request\"} | json | unwrap duration_ms [1m]",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "API Request ({{model}})"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "🟡 API Errors (429s, 500s, Timeouts)",
      "description": "API errors with duration — shows how long you wait before an error is returned. Your avg error wait is 195s.",
      "type": "table",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\", event_name=\"api_error\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "format": "auto"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      }
    },
    {
      "title": "🔧 Tool Execution Duration by Tool",
